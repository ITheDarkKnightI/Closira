{
  "name": "closira",
  "version": "1.0.0",
  "description": "Desktop screen translator with OCR",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder --win"
  },
  "dependencies": {
    "tesseract.js": "^5.1.0"
  },
  "devDependencies": {
    "electron": "^42.4.1"
  },
  "build": {
    "appId": "com.closira.app",
    "productName": "Closira",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "asar": true,
    "extraResources": [
      {
        "from": "resources",
        "to": "resources",
        "filter": [
          "**/*"
        ]
      }
    ]
  },
  "allowScripts": {
    "electron@29.4.6": true,
    "tesseract.js@5.1.1": true
  }
}
